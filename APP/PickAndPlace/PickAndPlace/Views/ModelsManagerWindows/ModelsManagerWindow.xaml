<Window
    x:Class="PickAndPlace.Views.ModelsManagerWindows.ModelsManagerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PickAndPlace.Views.ModelsManagerWindows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:PickAndPlace.Resources.Styles"
    xmlns:utils="clr-namespace:PickAndPlace.Utils"
    Title="Model Manager"
    Width="600"
    Height="690"
    Closing="Window_Closing"
    Icon="/Resources/Icons/condition.png"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <utils:BitmapSourceConverter x:Key="BitmapSourceConverter" />
        <utils:FileNameOnlyConverter x:Key="FileNameOnlyConverter" />
    </Window.Resources>
    <Border
        Margin="10"
        BorderBrush="Gray"
        BorderThickness="2"
        CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="279" />
                <RowDefinition Height="206" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <DockPanel Margin="10">
                    <ToolBar Background="Transparent">
                        <ToolBar.Resources>
                            <Style x:Key="btTool" TargetType="Button">
                                <Setter Property="Margin" Value="10,0,10,0" />
                            </Style>
                        </ToolBar.Resources>
                        <Label
                            VerticalAlignment="Center"
                            Content="Model:"
                            FontWeight="Bold" />
                        <ComboBox
                            x:Name="cbbModelNames"
                            Width="230"
                            Height="30"
                            Background="LightGray"
                            Cursor="Hand"
                            DisplayMemberPath="Name"
                            FontSize="15"
                            FontWeight="Regular"
                            ForceCursor="True"
                            IsReadOnly="True"
                            ItemsSource="{Binding ModelsList}"
                            SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                            ToolTip="List models" />

                        <Button
                            x:Name="btReload"
                            Background="Transparent"
                            Click="btReload_Click"
                            Style="{StaticResource btTool}"
                            ToolTip="Reload models">
                            <Image Source="/Resources/Icons/refresh.ico" />
                        </Button>
                        <Separator />
                        <Button
                            x:Name="btAddModel"
                            Click="btAddModel_Click"
                            Style="{StaticResource btTool}"
                            ToolTip="Add Model">
                            <Image Source="/Resources/Icons/newfileicon.png" />
                        </Button>
                        <Button
                            x:Name="btRemoveModel"
                            Click="btRemoveModel_Click"
                            IsEnabled="{Binding IsMoldelSelected}"
                            Style="{StaticResource btTool}"
                            ToolTip="Remove Model">
                            <Image Height="30" Source="/Resources/Icons/bin.png" />
                        </Button>
                        <Separator />
                    </ToolBar>
                </DockPanel>
            </Grid>
            <Grid Grid.Row="2">
                <GroupBox Margin="5,0,5,0" Header="Model Details:">
                    <GroupBox.HeaderTemplate>
                        <DataTemplate>
                            <Border>
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="Black"
                                    Text="{Binding}" />
                            </Border>
                        </DataTemplate>
                    </GroupBox.HeaderTemplate>

                    <Grid>
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Auto"
                            Opacity="0.7"
                            VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="10,10,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="Model Name:" />
                                    <Label
                                        x:Name="lbModelName"
                                        Content="{Binding SelectedModel.Name, FallbackValue='-----'}"
                                        FontWeight="Bold" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Label Content="Create Time:  " />
                                    <Label x:Name="lbTimeCreate" Content="{Binding SelectedModel.CreatedTime, FallbackValue='-----'}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" />
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="Robot Teaching Pose:" />
                                    <Label x:Name="lbRobotPose" Content="{Binding SelectedModel.Width, FallbackValue='-----'}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="Image Master Point:  " />
                                    <Label x:Name="lbMasterPoint" Content="{Binding SelectedModel.Height, FallbackValue='-----'}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="Templates:" />
                                    <Label x:Name="lbTemplate" Content="{Binding SelectedModel.Templates.Count, FallbackValue='-----'}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="Offset Calculation:" />
                                    <Label x:Name="lbOffsetCalculation" Content="{Binding SelectedModel.Templates.Count, FallbackValue='-----'}" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </GroupBox>
            </Grid>
            <Grid Grid.Row="1">
                <GroupBox Margin="5,0,5,0" Header="Job Specifications:">
                    <GroupBox.HeaderTemplate>
                        <DataTemplate>
                            <Border>
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="Black"
                                    Text="{Binding}" />
                            </Border>
                        </DataTemplate>
                    </GroupBox.HeaderTemplate>
                    <Grid>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <GroupBox Margin="5" Header="Robot Teaching Pose">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="3*" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="2*" />
                                        </Grid.RowDefinitions>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <StackPanel
                                                Margin="0,10,5,-5"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <StackPanel Margin="0,-10,0,0" VerticalAlignment="Center">
                                                    <Label
                                                        Margin="0,-10,0,0"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Content="X"
                                                        FontSize="12" />
                                                    <TextBox
                                                        Name="tbRobotX"
                                                        Width="65"
                                                        Height="25"
                                                        Margin="5,-5,0,0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        BorderBrush="DarkGray"
                                                        FontSize="14"
                                                        FontWeight="Bold"
                                                        IsReadOnly="False" />
                                                </StackPanel>
                                                <StackPanel Margin="15,-10,0,0" VerticalAlignment="Center">
                                                    <Label
                                                        Margin="0,-10,0,0"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Content="Y"
                                                        FontSize="12" />
                                                    <TextBox
                                                        Name="tbRobotY"
                                                        Width="65"
                                                        Height="25"
                                                        Margin="5,-5,0,0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        BorderBrush="DarkGray"
                                                        FontSize="14"
                                                        FontWeight="Bold"
                                                        IsReadOnly="False" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel
                                                Margin="0,10,5,-5"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <StackPanel Margin="0,10,0,0" VerticalAlignment="Center">
                                                    <Label
                                                        Margin="0,-10,0,0"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Content="Z"
                                                        FontSize="12" />
                                                    <TextBox
                                                        Name="tbRobotZ"
                                                        Width="65"
                                                        Height="25"
                                                        Margin="5,-5,0,0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        BorderBrush="DarkGray"
                                                        FontSize="14"
                                                        FontWeight="Bold"
                                                        IsReadOnly="False" />
                                                </StackPanel>
                                                <StackPanel Margin="15,10,0,0" VerticalAlignment="Center">
                                                    <Label
                                                        Margin="0,-10,0,0"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Content="RZ"
                                                        FontSize="12" />
                                                    <TextBox
                                                        Name="tbRobotRZ"
                                                        Width="65"
                                                        Height="25"
                                                        Margin="5,-5,0,0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        BorderBrush="DarkGray"
                                                        FontSize="14"
                                                        FontWeight="Bold"
                                                        IsReadOnly="False" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>

                                        <Grid Grid.Row="1">
                                            <Border
                                                Height="1"
                                                Margin="15,0,15,0"
                                                Background="DarkGray" />
                                        </Grid>
                                        <Grid Grid.Row="2">
                                            <uc:CustomButton2
                                                x:Name="btnGetRobotCoord"
                                                Title="Get Robot&#x0A;COORDINATE"
                                                Width="140"
                                                Height="55"
                                                EndColor="#1C4D8D"
                                                FontSize="12"
                                                IconHeight="27"
                                                IconWidth="30"
                                                LeftIcon="/Resources/Icons/geolocation.png"
                                                MouseDown="btnGetRobotCoord_MouseDown"
                                                StartColor="#C8AAAA" />

                                        </Grid>
                                    </Grid>
                                </GroupBox>
                            </Grid>
                            <Grid Grid.Column="1">
                                <Border
                                    Width="1"
                                    Margin="0,5,0,5"
                                    Background="DarkGray" />
                            </Grid>
                            <Grid Grid.Column="2">
                                <GroupBox Margin="5" Header="Master Image">
                                    <Grid>
                                        <ListBox
                                            x:Name="lbThumbList"
                                            Grid.Row="1"
                                            Margin="5,5,5,5"
                                            BorderThickness="0"
                                            ItemsSource="{Binding SelectedModel.Templates}"
                                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                            ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                            <ListBox.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Offset="0" Color="#d6cfc7" />
                                                    <GradientStop Offset="1" Color="#d9dddc" />
                                                </LinearGradientBrush>
                                            </ListBox.Background>
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Margin="5,5,5,0"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="2">
                                                        <StackPanel Width="100">
                                                            <Image
                                                                Width="100"
                                                                Height="80"
                                                                Source="{Binding Image, Converter={StaticResource BitmapSourceConverter}}"
                                                                Stretch="Uniform" />
                                                            <Label
                                                                Margin="0,0,0,0"
                                                                HorizontalAlignment="Center"
                                                                Content="{Binding ImagePath, Converter={StaticResource FileNameOnlyConverter}}"
                                                                FontSize="12" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>

                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="BorderThickness" Value="0" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="BorderBrush" Value="DodgerBlue" />
                                                            <Setter Property="BorderThickness" Value="2" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                        <StackPanel
                                            Margin="5"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Orientation="Horizontal">
                                            <Button
                                                x:Name="btnTemplateManager"
                                                Width="40"
                                                Height="40"
                                                Margin="0,0,0,0"
                                                Click="btnTemplateManager_Click"
                                                DockPanel.Dock="Right"
                                                IsEnabled="{Binding IsMoldelSelected}">
                                                <Image
                                                    Width="32"
                                                    Height="32"
                                                    Source="/Resources/Icons/image-setting.png"
                                                    Style="{DynamicResource imageButton}" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </GroupBox>
                            </Grid>
                        </Grid>
                    </Grid>
                </GroupBox>
            </Grid>
            <Grid Grid.Row="3">
                <Grid>
                    <uc:CustomButton
                        x:Name="btnSave"
                        Title="Save"
                        Width="150"
                        Height="70"
                        Margin="15,0,5,5"
                        EndColor="#e8b595"
                        IconHeight="40"
                        IconWidth="40"
                        IsEnabled="{Binding CanSave}"
                        LeftIcon="/Resources/Icons/save-2.png"
                        MouseDown="btnSave_MouseDown"
                        StartColor="#b190ba"
                        Value="MODEL" />
                </Grid>
            </Grid>
        </Grid>
    </Border>

</Window>
